	branch = main
	shallow = true

[submodule "vendors/microsoft/duroxide-pg"]
	path   = vendors/microsoft/duroxide-pg
	url    = https://github.com/microsoft/duroxide-pg
	branch = main
	shallow = true

[submodule "vendors/a2aproject/a2a-rs"]
	path   = vendors/a2aproject/a2a-rs
	url    = https://github.com/a2aproject/a2a-rs
	branch = main
	shallow = true

[submodule "vendors/a2aproject/a2a-js"]
	path   = vendors/a2aproject/a2a-js
	url    = https://github.com/a2aproject/a2a-js
	branch = main
