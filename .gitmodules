# Git submodules — vendor repos cloned read-only for local indexing.
# Populate:  git submodule update --init --depth 1
# Update:    git submodule update --remote --depth 1
# Or use:    ./scripts/setup-vendors.sh --update

[submodule "vendors/Kuberwastaken/claurst"]
	path   = vendors/Kuberwastaken/claurst
	url    = https://github.com/Kuberwastaken/claurst
	branch = main
	shallow = true

[submodule "vendors/modelcontextprotocol/servers"]
	path   = vendors/modelcontextprotocol/servers
	url    = https://github.com/modelcontextprotocol/servers
	branch = main
	shallow = true

[submodule "vendors/modelcontextprotocol/typescript-sdk"]
	path   = vendors/modelcontextprotocol/typescript-sdk
	url    = https://github.com/modelcontextprotocol/typescript-sdk
	branch = main
	shallow = true

[submodule "vendors/modelcontextprotocol/rust-sdk"]
	path   = vendors/modelcontextprotocol/rust-sdk
	url    = https://github.com/modelcontextprotocol/rust-sdk
	branch = main
	shallow = true

[submodule "vendors/opencoworkers/subagentjobs"]
	path   = vendors/opencoworkers/subagentjobs
	url    = https://github.com/opencoworkers/subagentjobs
	branch = main
	shallow = true

[submodule "vendors/microsoft/pg_durable"]
	path   = vendors/microsoft/pg_durable
